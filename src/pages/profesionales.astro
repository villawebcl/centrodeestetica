---
export const prerender = false;
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { supabase } from "@lib/supabase";

// 1. Obtener configuración
const { data: config } = await supabase
  .from("configuracion")
  .select("*")
  .single();

// 2. Obtener profesionales
const { data: professionals } = await supabase
  .from("profesionales")
  .select("*")
  .filter("activo", "eq", true);

const site = {
  name: config?.nombre_negocio || "Lumina Estetica",
  ctaHref: "/reservar"
};
---

<BaseLayout
  title="Profesionales"
  description={`Equipo profesional de ${site.name}.`}
>
  <section class="page-section">
    <SectionHeading
      eyebrow="Equipo"
      title="Profesionales que cuidan cada detalle de tu experiencia."
      text="Atencion cercana, protocolos claros y recomendaciones personalizadas para cada visita."
    />

    <div class="grid grid--3">
      {
        professionals?.map((professional) => (
          <article class="professional-card">
            <div class="professional-avatar" aria-hidden="true">
              {professional.foto_url ? <img src={professional.foto_url} alt="" loading="lazy" decoding="async" /> : professional.nombre.slice(0, 1)}
            </div>
            <span>8 años de experiencia</span>
            <h3>{professional.nombre}</h3>
            <strong>{professional.rol}</strong>
            <p>{professional.especialidad}</p>
            <p>{professional.bio}</p>
          </article>
        ))
      }
    </div>

    <div class="promo-band">
      <div>
        <p class="eyebrow">Primera visita</p>
        <h2>Si no sabes con quien agendar, te orientamos segun tu objetivo.</h2>
      </div>
      <a class="button" href={site.ctaHref}>Agendar evaluacion</a>
    </div>
  </section>
</BaseLayout>

<style>
  .professional-card {
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.48);
    backdrop-filter: blur(14px);
    box-shadow: 0 2px 12px rgba(60, 40, 100, 0.06);
    transition:
      transform 300ms var(--ease),
      box-shadow 300ms var(--ease),
      border-color 300ms var(--ease),
      background 300ms var(--ease);
    display: flex;
    min-height: 330px;
    flex-direction: column;
    gap: 14px;
    padding: 30px;
  }

  .professional-card:hover {
    border-color: rgba(255, 255, 255, 0.75);
    background: rgba(255, 255, 255, 0.68);
    box-shadow: 0 12px 40px rgba(60, 40, 100, 0.12);
    transform: translateY(-4px);
  }

  .professional-card h3 {
    margin: 6px 0 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.7rem;
    font-weight: 500;
    line-height: 1.12;
  }

  .professional-avatar {
    overflow: hidden;
    display: grid;
    width: 72px;
    height: 72px;
    place-items: center;
    border-radius: 50%;
    background: linear-gradient(145deg, rgba(123, 58, 72, 0.9), rgba(185, 120, 130, 0.78));
    color: white;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2rem;
    box-shadow: 0 18px 38px rgba(123, 58, 72, 0.18);
  }

  .professional-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .professional-card > span {
    color: var(--sage);
    font-size: 0.84rem;
    font-weight: 820;
  }

  .professional-card strong {
    color: var(--brand-secondary);
  }
</style>
