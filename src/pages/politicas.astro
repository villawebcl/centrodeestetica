---
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { supabase } from "@lib/supabase";
import { withTimeout } from "@lib/api";

const { data: config } = await withTimeout(
  supabase.from("configuracion").select("nombre_negocio, email, whatsapp_number").single(),
  2500,
  { data: null, error: null } as any
);

const site = {
  name: config?.nombre_negocio || "Lumina Estetica",
  email: config?.email || "hola@luminaestetica.cl",
  whatsappHref: `https://wa.me/${config?.whatsapp_number || "56987654321"}?text=Hola%2C%20tengo%20una%20consulta%20sobre%20mis%20datos`
};
---

<BaseLayout
  title="Politicas y privacidad"
  description={`Politicas de reservas y privacidad de ${site.name}.`}
  brandConfig={config}
>
  <section class="page-section">
    <SectionHeading
      eyebrow="Reservas"
      title="Politicas claras para cuidar tu tiempo y el de nuestro equipo."
      text="Queremos que cada visita sea ordenada, tranquila y respetuosa para todas nuestras clientas."
    />

    <div class="policy-grid">
      <article class="feature">
        <strong>Datos personales</strong>
        <p>Los formularios recopilan nombre, telefono, email opcional, servicio de interes, fecha, hora y mensaje para responder consultas y gestionar reservas.</p>
      </article>
      <article class="feature">
        <strong>Finalidad y consentimiento</strong>
        <p>Usamos tus datos solo para contactarte, coordinar atenciones, confirmar disponibilidad y mantener registro operativo de solicitudes.</p>
      </article>
      <article class="feature">
        <strong>Conservacion</strong>
        <p>Los datos se conservan mientras sean necesarios para administrar reservas, historial de atencion y obligaciones operativas o legales.</p>
      </article>
      <article class="feature">
        <strong>Derechos</strong>
        <p>Puedes pedir acceso, rectificacion o eliminacion de tus datos escribiendo a <a href={`mailto:${site.email}`}>{site.email}</a>.</p>
      </article>
      <article class="feature">
        <strong>Cookies tecnicas</strong>
        <p>El sitio usa cookies estrictamente necesarias para la sesion del admin y almacenamiento local para recordar el aviso de privacidad. No usamos cookies de publicidad o analitica en esta version.</p>
      </article>
      <article class="feature">
        <strong>Confirmacion</strong>
        <p>Tu solicitud queda pendiente hasta que nuestro equipo confirme disponibilidad por telefono o WhatsApp.</p>
      </article>
      <article class="feature">
        <strong>Reprogramaciones</strong>
        <p>Solicita cambios con al menos 24 horas de anticipacion para ofrecerte una nueva alternativa.</p>
      </article>
      <article class="feature">
        <strong>Atrasos</strong>
        <p>Un atraso mayor a 15 minutos puede reducir la duracion del servicio o requerir reagendar.</p>
      </article>
      <article class="feature">
        <strong>Abonos</strong>
        <p>Algunos planes o promociones pueden requerir abono previo para asegurar el horario.</p>
      </article>
    </div>

    <div class="promo-band">
      <div>
        <p class="eyebrow">Agenda responsable</p>
        <h2>Si necesitas ayuda, contactanos antes de tu visita.</h2>
      </div>
      <a class="button" href={site.whatsappHref} target="_blank" rel="noreferrer">Contactar</a>
    </div>
  </section>
</BaseLayout>
