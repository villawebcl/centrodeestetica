---
export const prerender = false;
import AdminLayout from "@layouts/AdminLayout.astro";
import { supabase } from "@lib/supabase";

const { data: config } = await supabase.from("configuracion").select("nombre_negocio").single();
const siteName = config?.nombre_negocio || "Lumina Estetica";
---

<AdminLayout title="Servicios" currentPage="servicios" siteName={siteName}>

  <div class="al-page-header">
    <div class="al-page-header__text">
      <span class="al-page-eyebrow">CMS / Servicios</span>
      <h1 class="al-page-title">Gestionar Tratamientos</h1>
      <p class="al-page-desc">Añade, edita o desactiva los servicios que se muestran en la web.</p>
    </div>
    <div class="al-page-actions">
      <button type="button" class="button" id="open-dialog-btn">+ Nuevo Servicio</button>
    </div>
  </div>

  <div class="admin-panel">
    <div class="svc-grid" id="services-list">
      <p class="svc-loading">Cargando servicios...</p>
    </div>
  </div>

  <dialog id="service-dialog" class="svc-dialog" aria-labelledby="svc-dialog-title">
    <div class="svc-dialog__inner">
      <div class="svc-dialog__header">
        <div>
          <p class="eyebrow" id="svc-dialog-eyebrow">Nuevo servicio</p>
          <h2 id="svc-dialog-title">Añadir tratamiento</h2>
        </div>
        <button type="button" class="svc-dialog__close" id="close-dialog-btn" aria-label="Cerrar">&#x2715;</button>
      </div>

      <div id="form-status" class="form-status" hidden></div>

      <form id="service-form" class="booking-form">
        <input type="hidden" name="id" id="service-id" />
        <input type="hidden" name="originalNombre" id="service-original-nombre" />

        <label>
          Nombre del servicio
          <input type="text" name="nombre" id="service-nombre" required placeholder="Ej: Limpieza profunda" />
        </label>

        <div class="form-grid">
          <label>
            Categoría
            <select name="categoria" id="service-categoria">
              <option value="Facial">Facial</option>
              <option value="Corporal">Corporal</option>
              <option value="Mirada">Mirada</option>
              <option value="Asesoria">Asesoría</option>
            </select>
          </label>
          <label>
            Duración
            <input type="text" name="duracion" id="service-duracion" placeholder="Ej: 60 min" />
          </label>
        </div>

        <label>
          Precio
          <input type="text" name="precio" id="service-precio" placeholder="Ej: $35.000" />
        </label>

        <label>
          Descripción corta
          <textarea name="descripcion" id="service-descripcion" rows="3" placeholder="Breve descripción del tratamiento..."></textarea>
        </label>

        <div class="svc-dialog__footer">
          <button type="button" class="button button--secondary" id="cancel-btn">Cancelar</button>
          <button type="submit" class="button" id="save-btn">Guardar servicio</button>
        </div>
      </form>
    </div>
  </dialog>

  <script type="module" is:inline>
    const list          = document.querySelector("#services-list");
    const dialog        = document.querySelector("#service-dialog");
    const form          = document.querySelector("#service-form");
    const saveBtn       = document.querySelector("#save-btn");
    const cancelBtn     = document.querySelector("#cancel-btn");
    const dialogTitle   = document.querySelector("#svc-dialog-title");
    const dialogEyebrow = document.querySelector("#svc-dialog-eyebrow");
    const formStatus    = document.querySelector("#form-status");
    const openBtn       = document.querySelector("#open-dialog-btn");
    const closeBtn      = document.querySelector("#close-dialog-btn");

    function showToast(message, isError = false) {
      const tc    = document.querySelector("#toast-container");
      const toast = document.createElement("div");
      toast.className = `svc-toast${isError ? " svc-toast--error" : " svc-toast--success"}`;
      toast.setAttribute("role", "status");
      toast.innerHTML = `<span class="svc-toast__icon">${isError ? "✕" : "✓"}</span><span>${message}</span>`;
      tc.appendChild(toast);
      requestAnimationFrame(() => toast.classList.add("svc-toast--visible"));
      setTimeout(() => {
        toast.classList.remove("svc-toast--visible");
        toast.addEventListener("transitionend", () => toast.remove(), { once: true });
      }, 4000);
    }

    function showStatus(message, isError = false) {
      formStatus.textContent = message;
      formStatus.className   = isError ? "form-status form-status--error" : "form-status form-status--success";
      formStatus.hidden      = false;
      setTimeout(() => { formStatus.hidden = true; }, 4000);
    }

    function openDialog(editMode = false) {
      dialogEyebrow.textContent = editMode ? "Editar servicio" : "Nuevo servicio";
      dialogTitle.textContent   = editMode ? "Editar tratamiento" : "Añadir tratamiento";
      saveBtn.textContent       = editMode ? "Actualizar servicio" : "Guardar servicio";
      formStatus.hidden         = true;
      dialog.showModal();
    }

    function closeDialog() { dialog.close(); resetForm(); }

    openBtn.addEventListener("click",  () => { resetForm(); openDialog(false); });
    closeBtn.addEventListener("click", closeDialog);
    cancelBtn.addEventListener("click", closeDialog);
    dialog.addEventListener("click",   (e) => { if (e.target === dialog) closeDialog(); });

    function escapeHtml(v = "") {
      return String(v).replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;")
        .replaceAll('"',"&quot;").replaceAll("'","&#039;");
    }

    function normalizeKey(name) { return String(name || "").trim().toLowerCase(); }

    function getUnique(services) {
      const map = new Map();
      services.forEach((s) => {
        const key = normalizeKey(s.nombre || s.id);
        const cur = map.get(key);
        if (!cur) { map.set(key, { ...s, dupeCount: 1 }); return; }
        cur.dupeCount++;
        if (!cur.activo && s.activo) map.set(key, { ...s, dupeCount: cur.dupeCount });
      });
      return [...map.values()];
    }

    async function render() {
      const res      = await fetch("/api/admin/servicios");
      const result   = await res.json();
      const services = getUnique(result.data || []);
      list.innerHTML = "";

      if (services.length === 0) {
        list.innerHTML = `<p class="svc-empty">No hay servicios creados todavía.</p>`;
        return;
      }

      services.forEach((s) => {
        const card = document.createElement("article");
        card.className = `svc-card${s.activo ? "" : " svc-card--inactive"}`;
        const id = escapeHtml(s.id), name = escapeHtml(s.nombre);
        card.innerHTML = `
          <div class="svc-card__top">
            <div class="svc-card__badges">
              <span class="status-pill svc-cat-pill">${escapeHtml(s.categoria)}</span>
              ${!s.activo       ? `<span class="svc-badge svc-badge--off">Oculto</span>` : ""}
              ${s.dupeCount > 1 ? `<span class="svc-badge svc-badge--warn">${s.dupeCount} copias</span>` : ""}
            </div>
            <div class="svc-card__btns">
              <button class="svc-btn action-edit" data-id="${id}">Editar</button>
              <button class="svc-btn action-toggle" data-name="${name}" data-active="${s.activo}">
                ${s.activo ? "Ocultar" : "Mostrar"}
              </button>
              <button class="svc-btn svc-btn--danger action-delete" data-name="${name}">Eliminar</button>
            </div>
          </div>
          <h3 class="svc-card__name">${name}</h3>
          <p class="svc-card__desc">${escapeHtml(s.descripcion || "Sin descripción")}</p>
          <div class="svc-card__price">
            <strong>${escapeHtml(s.precio)}</strong>
            <span class="svc-card__dur">&nbsp;·&nbsp;${escapeHtml(s.duracion)}</span>
          </div>`;
        list.append(card);
      });
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      saveBtn.disabled = true;
      saveBtn.textContent = "Guardando...";
      const fd     = new FormData(form);
      const id     = document.querySelector("#service-id").value;
      const orig   = document.querySelector("#service-original-nombre").value;
      const isEdit = Boolean(id);
      const payload = {
        nombre: fd.get("nombre"), categoria: fd.get("categoria"),
        duracion: fd.get("duracion"), precio: fd.get("precio"), descripcion: fd.get("descripcion"),
      };
      try {
        const url  = "/api/admin/servicios";
        const opts = (m, b) => ({ method: m, headers: { "content-type": "application/json" }, body: JSON.stringify(b) });
        const res  = isEdit
          ? await fetch(url, opts("PATCH", { id, originalNombre: orig, payload }))
          : await fetch(url, opts("POST",  payload));
        const r = await res.json();
        if (!res.ok) throw new Error(r.error || "Error al guardar.");
        dialog.close(); resetForm(); await render();
        showToast(isEdit ? "Servicio actualizado." : "Servicio creado.");
      } catch (err) { showStatus("Error: " + err.message, true); }
      finally {
        saveBtn.disabled    = false;
        saveBtn.textContent = id ? "Actualizar servicio" : "Guardar servicio";
      }
    });

    list.addEventListener("click", async (e) => {
      const btn  = e.target.closest("button");
      if (!btn) return;
      const id   = btn.dataset.id;
      const name = btn.dataset.name;

      if (btn.classList.contains("action-delete")) {
        if (!confirm(`¿Eliminar "${name}"?`)) return;
        btn.disabled = true;
        const res = await fetch("/api/admin/servicios", { method: "DELETE", headers: { "content-type": "application/json" }, body: JSON.stringify({ nombre: name }) });
        if (!res.ok) { const r = await res.json(); showToast("Error: " + r.error, true); btn.disabled = false; return; }
        await render(); showToast(`"${name}" eliminado.`);

      } else if (btn.classList.contains("action-toggle")) {
        const active = btn.dataset.active === "true";
        btn.disabled = true;
        const res = await fetch("/api/admin/servicios", { method: "PATCH", headers: { "content-type": "application/json" }, body: JSON.stringify({ nombre: name, payload: { activo: !active } }) });
        if (!res.ok) { const r = await res.json(); showToast("Error: " + r.error, true); btn.disabled = false; return; }
        await render(); showToast(active ? `"${name}" ocultado.` : `"${name}" visible en la web.`);

      } else if (btn.classList.contains("action-edit")) {
        const res    = await fetch(`/api/admin/servicios?id=${encodeURIComponent(id)}`);
        const result = await res.json();
        if (!res.ok || !result.data) { showToast(result.error || "Error al cargar.", true); return; }
        const d = result.data;
        document.querySelector("#service-id").value              = d.id;
        document.querySelector("#service-original-nombre").value = d.nombre;
        document.querySelector("#service-nombre").value          = d.nombre;
        document.querySelector("#service-categoria").value       = d.categoria;
        document.querySelector("#service-duracion").value        = d.duracion;
        document.querySelector("#service-precio").value          = d.precio;
        document.querySelector("#service-descripcion").value     = d.descripcion;
        openDialog(true);
      }
    });

    function resetForm() {
      form.reset();
      document.querySelector("#service-id").value              = "";
      document.querySelector("#service-original-nombre").value = "";
    }

    render();
  </script>

</AdminLayout>
