---
export const prerender = false;
import AdminLayout from "@layouts/AdminLayout.astro";
import { supabase } from "@lib/supabase";

const { data: config } = await supabase.from("configuracion").select("nombre_negocio").single();
const siteName = config?.nombre_negocio || "Lumina Estetica";
---

<AdminLayout title="Cuenta" currentPage="cuenta" siteName={siteName}>

  <div class="al-page-header">
    <div class="al-page-header__text">
      <span class="al-page-eyebrow">Sistema / Cuenta</span>
      <h1 class="al-page-title">Cambiar contraseña</h1>
      <p class="al-page-desc">Actualiza la contraseña con la que accedes a este panel.</p>
    </div>
  </div>

  <div class="admin-panel config-panel">
    <form id="cuenta-form" class="booking-form">
      <fieldset class="config-section">
        <legend>Seguridad</legend>

        <label>
          Contraseña actual
          <input type="password" id="current-password" name="current_password" required
            placeholder="••••••••" autocomplete="current-password" />
        </label>

        <div class="form-grid">
          <label>
            Nueva contraseña
            <input type="password" id="new-password" name="new_password" required
              placeholder="Mín. 8, Aa, número y símbolo" autocomplete="new-password" minlength="8" />
          </label>
          <label>
            Confirmar contraseña
            <input type="password" id="confirm-password" name="confirm_password" required
              placeholder="Repite la contraseña" autocomplete="new-password" minlength="8" />
          </label>
        </div>

        <p class="field-hint">
          Usa al menos 8 caracteres con mayúscula, minúscula, número y símbolo.
          Si olvidaste la contraseña actual, pide ayuda al desarrollador.
        </p>
      </fieldset>

      <div class="config-footer">
        <button type="submit" class="button" id="save-btn">Cambiar contraseña</button>
      </div>
    </form>
  </div>

  <script type="module" is:inline>
    const form    = document.querySelector("#cuenta-form");
    const saveBtn = document.querySelector("#save-btn");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const newPass     = document.querySelector("#new-password").value;
      const confirmPass = document.querySelector("#confirm-password").value;

      if (newPass !== confirmPass) {
        showToast("Las contraseñas no coinciden.", true);
        return;
      }
      if (!/(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}/.test(newPass)) {
        showToast("La contraseña debe incluir mayúscula, minúscula, número y símbolo.", true);
        return;
      }

      saveBtn.disabled = true;
      saveBtn.textContent = "Guardando...";

      try {
        const res = await fetch("/api/admin/cuenta", {
          method: "PATCH",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            current_password:  document.querySelector("#current-password").value,
            new_password:      newPass,
            confirm_password:  confirmPass,
          }),
        });
        const r = await res.json();
        if (!res.ok) throw new Error(r.error || "Error al guardar.");
        showToast("Contraseña actualizada correctamente.");
        form.reset();
      } catch (err) {
        showToast("Error: " + err.message, true);
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = "Cambiar contraseña";
      }
    });
  </script>

</AdminLayout>
