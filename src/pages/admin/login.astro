---
export const prerender = false;
import LoginLayout from "@layouts/LoginLayout.astro";
import { getClientIp, isRateLimited } from "@lib/api";
import { setAdminSessionCookie, safeEqual, verifyHashedPassword } from "@lib/adminAuth";
import { createSupabaseAdminClient } from "@lib/supabaseAdmin";

const supabase = createSupabaseAdminClient();
const { data: config } = await supabase
  .from("configuracion")
  .select("nombre_negocio, password_hash")
  .single();

const siteName = config?.nombre_negocio || "Mi Centro";
let error = "";

if (Astro.request.method === "POST") {
  try {
    const ip = getClientIp(Astro.request);
    if (isRateLimited(`admin-login:${ip}`, 8, 15 * 60 * 1000)) {
      error = "Demasiados intentos. Intenta nuevamente en unos minutos.";
    } else {
      const data = await Astro.request.formData();
      const password = String(data.get("password") ?? "");

      let isValid = false;
      if (config?.password_hash) {
        isValid = await verifyHashedPassword(password, config.password_hash);
      } else {
        const envPass = import.meta.env.ADMIN_PASSWORD ?? "";
        isValid = envPass.length > 0 && safeEqual(password, envPass);
      }

      if (isValid) {
        await setAdminSessionCookie(Astro);
        return Astro.redirect("/admin");
      } else {
        error = "Contraseña incorrecta.";
      }
    }
  } catch (e) {
    console.error(e);
    error = "Error interno. Intenta de nuevo.";
  }
}
---

<LoginLayout siteName={siteName}>
  <h1 class="login-title">Bienvenido</h1>
  <p class="login-subtitle">Ingresa tu contraseña para gestionar el panel.</p>

  <form method="POST" class="login-form">
    <label>
      Contraseña
      <input
        type="password"
        name="password"
        required
        placeholder="••••••••"
        autocomplete="current-password"
        autofocus
      />
    </label>

    {error && <p class="login-error" role="alert">{error}</p>}

    <button class="button" type="submit" style="width:100%;margin-top:0.25rem;">
      Entrar al panel
    </button>
  </form>
</LoginLayout>
