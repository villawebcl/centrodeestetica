---
import ServiceCard from "@components/ServiceCard.astro";
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { supabase } from "@lib/supabase";

// 1. Obtener configuración
const { data: config } = await supabase
  .from("configuracion")
  .select("*")
  .single();

// 2. Obtener servicios
const { data: serviceRows } = await supabase
  .from("servicios")
  .select("*")
  .filter("activo", "eq", true)
  .order("orden", { ascending: true });

const services = serviceRows ?? [];
const visibleServices = [
  ...new Map(
    services.map((service) => [
      String(service.nombre || service.id).trim().toLowerCase(),
      service
    ])
  ).values()
];
const categories = [
  ...new Set(visibleServices.map((service) => service.categoria).filter(Boolean))
];
const site = {
  name: config?.nombre_negocio || "Lumina Estetica",
  ctaHref: "/reservar"
};
---

<BaseLayout
  title="Servicios"
  description={`Servicios esteticos faciales y corporales de ${site.name}.`}
>
  <section class="page-section">
    <SectionHeading
      eyebrow="Tratamientos"
      title="Elige tu tratamiento o comienza con una evaluacion personalizada."
      text="Cada servicio se adapta segun tu piel, objetivo y frecuencia recomendada por nuestra especialista."
    />
    <div class="grid grid--3">
      {visibleServices.map((service) => <ServiceCard service={service} />)}
    </div>
  </section>

  <section class="page-section">
    <div class="promo-band">
      <div>
        <p class="eyebrow">Categorias disponibles</p>
        <h2>{categories.join(", ")}</h2>
        <p>
          Si no sabes que tratamiento elegir, agenda una evaluacion y te
          orientaremos con una recomendacion clara y segura.
        </p>
      </div>
      <a class="button" href={site.ctaHref}>
        Pedir recomendacion
      </a>
    </div>
  </section>
</BaseLayout>
