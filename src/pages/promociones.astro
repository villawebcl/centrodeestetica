---
export const prerender = false;
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { supabase } from "@lib/supabase";

// 1. Obtener configuración
const { data: config } = await supabase
  .from("configuracion")
  .select("*")
  .single();

// 2. Obtener promociones
const { data: promotions } = await supabase
  .from("promociones")
  .select("*")
  .filter("activo", "eq", true);

const site = {
  name: config?.nombre_negocio || "Lumina Estetica",
  ctaHref: "/reservar"
};
---

<BaseLayout
  title="Promociones"
  description={`Promociones y planes esteticos de ${site.name} en Santiago.`}
>
  <section class="page-section">
    <SectionHeading
      eyebrow="Promociones"
      title="Planes seleccionados para cuidar tu piel y bienestar este mes."
      text="Opciones pensadas para comenzar con una experiencia completa, con orientacion profesional y agenda simple."
    />

    <div class="grid grid--3">
      {
        promotions?.map((promotion) => (
          <article class="promo-card">
            <span class="status-pill">{promotion.tag}</span>
            <h3>{promotion.name}</h3>
            <p>{promotion.descripcion}</p>
            <div class="price-row">
              <strong>{promotion.precio}</strong>
              <span>{promotion.precio_antes}</span>
            </div>
            <ul>
              {promotion.incluye?.map((item: string) => <li>{item}</li>)}
            </ul>
            <a class="button button--secondary" href={site.ctaHref}>Reservar promocion</a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
