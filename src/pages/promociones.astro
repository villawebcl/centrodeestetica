---
export const prerender = false;
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { supabase } from "@lib/supabase";

// 1. Obtener configuración
const { data: config } = await supabase
  .from("configuracion")
  .select("*")
  .single();

// 2. Obtener promociones
const { data: promotions } = await supabase
  .from("promociones")
  .select("*")
  .filter("activo", "eq", true);

const site = {
  name: config?.nombre_negocio || "Lumina Estetica",
  ctaHref: "/reservar"
};
---

<BaseLayout
  title="Promociones"
  description={`Promociones y planes esteticos de ${site.name} en Santiago.`}
>
  <section class="page-section">
    <SectionHeading
      eyebrow="Promociones"
      title="Planes seleccionados para cuidar tu piel y bienestar este mes."
      text="Opciones pensadas para comenzar con una experiencia completa, con orientacion profesional y agenda simple."
    />

    <div class="grid grid--3">
      {
        promotions?.map((promotion) => (
          <article class="promo-card">
            <span class="status-pill">{promotion.tag}</span>
            <h3>{promotion.nombre}</h3>
            <p>{promotion.descripcion}</p>
            <div class="price-row">
              <strong>{promotion.precio}</strong>
              <span>{promotion.precio_antes}</span>
            </div>
            <ul>
              {promotion.incluye?.map((item: string) => <li>{item}</li>)}
            </ul>
            <a class="button button--secondary" href={site.ctaHref}>Reservar promocion</a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .promo-card {
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.48);
    backdrop-filter: blur(14px);
    box-shadow: 0 2px 12px rgba(60, 40, 100, 0.06);
    transition:
      transform 300ms var(--ease),
      box-shadow 300ms var(--ease),
      border-color 300ms var(--ease),
      background 300ms var(--ease);
    display: flex;
    min-height: 330px;
    flex-direction: column;
    gap: 14px;
    padding: 30px;
  }

  .promo-card:hover {
    border-color: rgba(255, 255, 255, 0.75);
    background: rgba(255, 255, 255, 0.68);
    box-shadow: 0 12px 40px rgba(60, 40, 100, 0.12);
    transform: translateY(-4px);
  }

  .promo-card h3 {
    margin: 6px 0 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.7rem;
    font-weight: 500;
    line-height: 1.12;
  }

  .promo-card ul {
    display: grid;
    gap: 8px;
    margin: 8px 0 0;
    padding-left: 18px;
    color: var(--muted);
  }

  .price-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-top: auto;
  }

  .price-row strong {
    color: var(--brand-secondary);
    font-size: 1.55rem;
  }

  .price-row span {
    color: rgba(117, 105, 101, 0.68);
    text-decoration: line-through;
  }
</style>
