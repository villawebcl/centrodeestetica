---
export const prerender = false;
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { supabase } from "@lib/supabase";

// 1. Obtener configuración
const { data: config } = await supabase
  .from("configuracion")
  .select("*")
  .single();

// 2. Obtener FAQs
const { data: faqs } = await supabase
  .from("faqs")
  .select("*")
  .order("orden", { ascending: true });

const site = {
  name: config?.nombre_negocio || "Lumina Estetica",
  whatsappHref: `https://wa.me/${config?.whatsapp_number}?text=Hola%20${config?.nombre_negocio}%2C%20tengo%20una%20pregunta`
};
---

<BaseLayout
  title="Preguntas frecuentes"
  description={`Preguntas frecuentes sobre tratamientos, reservas y cuidados en ${site.name}.`}
>
  <section class="page-section">
    <SectionHeading
      eyebrow="FAQ"
      title="Resolvemos tus dudas antes de reservar."
      text="Informacion clara para que llegues a tu primera visita con tranquilidad."
    />

    <div class="faq-list">
      {
        faqs?.map((faq) => (
          <details class="faq-item">
            <summary>{faq.pregunta}</summary>
            <p>{faq.respuesta}</p>
          </details>
        ))
      }
    </div>

    <div class="conversion-strip">
      <span>Si tienes una pregunta especifica, podemos orientarte antes de agendar.</span>
      <a href={site.whatsappHref} target="_blank" rel="noreferrer">Escribir por WhatsApp</a>
    </div>
  </section>
</BaseLayout>

<style>
  .faq-list {
    display: grid;
    gap: 14px;
    margin-bottom: 28px;
  }

  .faq-item {
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.48);
    backdrop-filter: blur(14px);
    box-shadow: 0 2px 12px rgba(60, 40, 100, 0.06);
    transition:
      transform 300ms var(--ease),
      box-shadow 300ms var(--ease),
      border-color 300ms var(--ease),
      background 300ms var(--ease);
    padding: 0;
  }

  .faq-item:hover {
    border-color: rgba(255, 255, 255, 0.75);
    background: rgba(255, 255, 255, 0.68);
    box-shadow: 0 12px 40px rgba(60, 40, 100, 0.12);
    transform: translateY(-4px);
  }

  .faq-item summary {
    cursor: pointer;
    color: var(--ink);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.3rem;
    font-weight: 500;
    list-style: none;
    padding: 24px 28px;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    float: right;
    color: var(--rose-dark);
    content: "+";
    font-family: Inter, sans-serif;
    font-weight: 800;
    transition: transform 240ms var(--ease);
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    margin: 0;
    padding: 0 28px 26px;
  }
</style>

