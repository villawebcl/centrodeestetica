---
export const prerender = false;
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { supabase } from "@lib/supabase";

// 1. Obtener configuración
const { data: config } = await supabase
  .from("configuracion")
  .select("*")
  .single();

// 2. Obtener FAQs
const { data: faqs } = await supabase
  .from("faqs")
  .select("*")
  .order("orden", { ascending: true });

const site = {
  name: config?.nombre_negocio || "Lumina Estetica",
  whatsappHref: `https://wa.me/${config?.whatsapp_number}?text=Hola%20${config?.nombre_negocio}%2C%20tengo%20una%20pregunta`
};
---

<BaseLayout
  title="Preguntas frecuentes"
  description={`Preguntas frecuentes sobre tratamientos, reservas y cuidados en ${site.name}.`}
>
  <section class="page-section">
    <SectionHeading
      eyebrow="FAQ"
      title="Resolvemos tus dudas antes de reservar."
      text="Informacion clara para que llegues a tu primera visita con tranquilidad."
    />

    <div class="faq-list">
      {
        faqs?.map((faq) => (
          <details class="faq-item">
            <summary>{faq.pregunta}</summary>
            <p>{faq.respuesta}</p>
          </details>
        ))
      }
    </div>

    <div class="conversion-strip">
      <span>Si tienes una pregunta especifica, podemos orientarte antes de agendar.</span>
      <a href={site.whatsappHref} target="_blank" rel="noreferrer">Escribir por WhatsApp</a>
    </div>
  </section>
</BaseLayout>

