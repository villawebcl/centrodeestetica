---
export const prerender = false;
import ServiceCard from "@components/ServiceCard.astro";
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { supabase } from "@lib/supabase";
import { testimonials } from "@data/testimonials";
import { withTimeout } from "@lib/api";

const heroImage = "/hero.webp";

const [
  { data: config },
  { data: services },
  { data: promotions },
  { data: professionals }
] = await withTimeout(Promise.all([
  supabase.from("configuracion").select("*").single(),
  supabase.from("servicios").select("*").filter("activo", "eq", true).order("orden", { ascending: true }).limit(3),
  supabase.from("promociones").select("*").filter("activo", "eq", true),
  supabase.from("profesionales").select("*").filter("activo", "eq", true)
]), 3000, [
  { data: null, error: null },
  { data: [], error: null },
  { data: [], error: null },
  { data: [], error: null }
] as any);

const site = {
  name: config?.nombre_negocio || "Lumina Estetica",
  ctaHref: "/reservar",
  // Mantenemos estas por ahora mientras migramos el resto
  whatsappHref: `https://wa.me/${config?.whatsapp_number}?text=Hola%20${config?.nombre_negocio}%2C%20quiero%20agendar%20una%20evaluacion`
};
---

<BaseLayout title={site.name} brandConfig={config}>
  <section class="hero">
    <div class="hero__content">
      <p class="eyebrow">{config?.tagline || "Estetica avanzada · Santiago"}</p>
      <h1>Cuidado<br><em>facial</em> y<br>corporal</h1>
      <p class="hero__desc">{config?.horarios || "Lunes a sabado · 10:00 a 19:30"}</p>
      <div class="hero-actions">
        <a class="button" href={site.ctaHref}>Agenda tu evaluacion</a>
        <a class="button button--secondary" href="/servicios">Ver servicios</a>
      </div>
      <div class="proof-row" aria-label="Sellos de confianza">
        <span>Evaluacion personalizada</span>
        <span class="proof-sep" aria-hidden="true">·</span>
        <span>Protocolos higienicos</span>
        <span class="proof-sep" aria-hidden="true">·</span>
        <span>Atencion profesional</span>
      </div>
    </div>
    <div class="hero__visual" aria-hidden="true">
      <div class="hero__photo">
        <img
          src={heroImage}
          alt=""
          width={1280}
          height={698}
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <section class="page-section compact-section">
    <div class="conversion-strip">
      <span>{config?.descripcion}</span>
      <a href="/contacto">Contactar al centro</a>
    </div>
  </section>

  <section class="page-section">
    <SectionHeading
      eyebrow="Servicios destacados"
      title="Tratamientos pensados para cuidar tu piel, tu cuerpo y tu bienestar."
      text="Elige una atencion puntual o comienza con una evaluacion para definir un plan de cuidado progresivo."
    />
    <div class="grid grid--3">
      {services?.map((service: any) => <ServiceCard service={service} />)}
    </div>
  </section>

  <section class="page-section">
    <SectionHeading
      eyebrow="Promociones"
      title="Planes del mes para comenzar con una experiencia completa."
      text="Tratamientos seleccionados para renovar tu piel, cuidar tu cuerpo o definir tu mirada."
    />
    <div class="grid grid--3">
      {
        promotions?.map((promotion: any) => (
          <article class="promo-card">
            <span class="status-pill">{promotion.tag}</span>
            <h3>{promotion.nombre}</h3>
            <p>{promotion.descripcion}</p>
            <div class="price-row">
              <strong>{promotion.precio}</strong>
              <span>{promotion.precio_antes}</span>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <div class="section-band section-band--warm">
    <section class="page-section">
      <SectionHeading
        eyebrow="Nuestra experiencia"
        title="Un espacio calido con estandares profesionales."
      />
      <div class="features-asymmetric">
        <article class="feature feature--large">
          <strong>Evaluacion honesta</strong>
          <p>Te orientamos con recomendaciones claras, sin promesas irreales ni tratamientos innecesarios. Cada sesion comienza con una lectura real de tu piel y tus objetivos.</p>
        </article>
        <div class="features-stack">
          <article class="feature feature--compact">
            <strong>Ambiente cuidado</strong>
            <p>Cabinas limpias, luz suave, productos seleccionados y una atencion pausada.</p>
          </article>
          <article class="feature feature--compact">
            <strong>Seguimiento cercano</strong>
            <p>Te indicamos cuidados posteriores y frecuencia sugerida para mantener resultados.</p>
          </article>
        </div>
      </div>
    </section>
  </div>

  <section class="page-section">
    <SectionHeading
      eyebrow="Equipo"
      title="Atencion profesional y cercana."
      text="Cada visita es guiada por especialistas que priorizan cuidado, higiene y una recomendacion honesta."
    />
    <div class="grid grid--3">
      {
        professionals?.map((professional: any) => (
          <article class="professional-card">
            <div class="professional-avatar" aria-hidden="true">
              {professional.foto_url ? <img src={professional.foto_url} alt="" loading="lazy" decoding="async" /> : professional.nombre ? professional.nombre.slice(0, 1) : "?"}
            </div>
            <span>8 años de experiencia</span>
            <h3>{professional.nombre || "Profesional"}</h3>
            <strong>{professional.rol || "Especialista"}</strong>
            <p>{professional.especialidad || ""}</p>
          </article>
        ))
      }
    </div>
  </section>

  <div class="section-band section-band--sage">
    <section class="page-section">
      <SectionHeading
        eyebrow="Como trabajamos"
        title="Un recorrido simple para sentirte acompanada de principio a fin."
        text="Desde la primera consulta hasta el cuidado posterior, mantenemos un proceso claro, calmado y profesional."
      />
      <div class="steps-flow">
        <div class="step">
          <span class="step__num">01</span>
          <h3>Evaluamos</h3>
          <p>Conversamos sobre tus objetivos, antecedentes relevantes y rutina actual.</p>
        </div>
        <div class="step">
          <span class="step__num">02</span>
          <h3>Personalizamos</h3>
          <p>Definimos el tratamiento, activos y frecuencia mas adecuada para ti.</p>
        </div>
        <div class="step">
          <span class="step__num">03</span>
          <h3>Acompanamos</h3>
          <p>Entregamos cuidados posteriores y resolvemos tus dudas despues de la sesion.</p>
        </div>
      </div>
    </section>
  </div>

  <section class="page-section">
    <div class="promo-band promo-band--dark">
      <div>
        <p class="eyebrow">Promocion del mes</p>
        <h2>Limpieza facial profunda + evaluacion personalizada.</h2>
        <p>
          Ideal para renovar la piel, mejorar textura y recibir una recomendacion
          profesional para tus proximos cuidados.
        </p>
      </div>
      <a class="button" href={site.ctaHref}>
        Consultar promo
      </a>
    </div>
  </section>

  <section class="page-section">
    <SectionHeading eyebrow="Experiencias" title="Clientes que vuelven por el trato." />
    <div class="grid grid--3">
      {
        testimonials.map((testimonial) => (
          <article class="testimonial">
            <div class="testimonial__stars" aria-label="5 de 5 estrellas">★★★★★</div>
            <p>"{testimonial.text}"</p>
            <div class="testimonial__footer">
              <strong>{testimonial.name}</strong>
              <span>{testimonial.treatment}</span>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────────── */

  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 48px 0;
    gap: 64px;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero h1 {
    margin: 20px 0 24px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3rem, 4.5vw, 5rem);
    font-style: normal;
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: var(--ink);
  }

  .hero h1 em {
    font-style: italic;
    font-weight: 400;
    color: var(--rose-dark);
  }

  .hero__desc {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 32px;
  }

  .hero__visual {
    position: relative;
    display: flex;
    align-items: flex-start;
  }

  .hero__photo {
    overflow: hidden;
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 220px 220px 160px 160px;
    background: var(--blush);
  }

  .hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: saturate(0.9);
    transition: transform 600ms var(--ease), filter 400ms var(--ease);
  }

  .hero__photo:hover img {
    filter: saturate(1);
    transform: scale(1.02);
  }


  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 32px;
  }

  .proof-row {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 6px 10px;
  }

  .proof-row span {
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.75;
    white-space: nowrap;
  }

  .proof-sep {
    color: var(--muted);
    opacity: 0.35 !important;
  }

  .hero-panel {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface);
    backdrop-filter: blur(18px);
    box-shadow: var(--shadow);
    transition: transform 320ms var(--ease), box-shadow 320ms var(--ease), border-color 320ms var(--ease);
  }

  .hero-panel:hover {
    border-color: rgba(123, 58, 72, 0.18);
    box-shadow: var(--shadow-hover);
    transform: translateY(-5px);
  }

  .hero-visual {
    min-height: 360px;
    background: linear-gradient(145deg, rgba(123, 58, 72, 0.1), rgba(246, 232, 228, 0.18));
    background-position: center;
    background-size: cover;
    filter: saturate(0.9);
    transition: transform 800ms var(--ease), filter 500ms var(--ease);
  }

  .hero-panel:hover .hero-visual {
    filter: saturate(0.98);
    transform: scale(1.035);
  }

  .hero-panel__content {
    display: grid;
    gap: 12px;
    padding: 24px;
  }

  .mini-calendar {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .mini-calendar div {
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(251, 247, 243, 0.78);
    padding: 14px;
    transition: transform 240ms var(--ease), border-color 240ms var(--ease), background 240ms var(--ease);
  }

  .mini-calendar div:hover {
    border-color: rgba(123, 58, 72, 0.2);
    background: rgba(255, 255, 255, 0.9);
    transform: translateY(-2px);
  }

  .mini-calendar span {
    display: block;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .mini-calendar strong {
    display: block;
    margin-top: 4px;
    color: var(--rose-dark);
  }

  .stat-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--line);
  }

  .stat-row div {
    padding: 18px;
    border-right: 1px solid var(--line);
  }

  .stat-row div:last-child {
    border-right: 0;
  }

  .stat-row strong {
    display: block;
    font-size: 1.2rem;
  }

  .stat-row span {
    color: var(--muted);
    font-size: 0.86rem;
  }

  /* ── Features ────────────────────────────────────────── */

  .feature,
  .testimonial {
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.48);
    backdrop-filter: blur(14px);
    box-shadow: 0 2px 12px rgba(60, 40, 100, 0.06);
    transition:
      transform 300ms var(--ease),
      box-shadow 300ms var(--ease),
      border-color 300ms var(--ease),
      background 300ms var(--ease);
    padding: 28px;
  }

  .feature:hover,
  .testimonial:hover {
    border-color: rgba(255, 255, 255, 0.75);
    background: rgba(255, 255, 255, 0.68);
    box-shadow: 0 12px 40px rgba(60, 40, 100, 0.12);
    transform: translateY(-4px);
  }

  .feature strong {
    color: var(--rose-dark);
  }

  .system-preview {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .system-card {
    position: relative;
    min-height: 240px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 30px;
    box-shadow: 0 18px 48px rgba(77, 55, 48, 0.07);
    transition:
      transform 300ms var(--ease),
      box-shadow 300ms var(--ease),
      border-color 300ms var(--ease),
      background 300ms var(--ease);
  }

  .system-card:hover {
    border-color: rgba(123, 58, 72, 0.2);
    box-shadow: var(--shadow-hover);
    transform: translateY(-6px);
  }

  .system-card::after {
    position: absolute;
    right: -28px;
    bottom: -28px;
    width: 110px;
    height: 110px;
    border: 1px solid rgba(183, 95, 114, 0.3);
    border-radius: 50%;
    content: "";
  }

  .system-card span {
    display: inline-flex;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #f4ede8;
    color: var(--rose-dark);
    font-weight: 850;
  }

  .system-card strong {
    display: block;
    margin-top: 22px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.45rem;
    font-weight: 500;
  }

  .system-card.is-active {
    background: linear-gradient(145deg, var(--rose-dark), #9b5360);
    color: white;
  }

  .system-card.is-active p {
    color: rgba(255, 255, 255, 0.78);
  }

  .system-card.is-active span {
    background: rgba(255, 255, 255, 0.16);
    color: white;
  }

  /* ── Section bands ───────────────────────────────────── */

  .section-band {
    width: 100%;
  }

  .section-band--dark {
    background: linear-gradient(148deg, #1a0a10 0%, #2a1320 55%, #1d0c15 100%);
  }

  .section-band--sage {
    background: linear-gradient(180deg, rgba(116, 136, 116, 0.09) 0%, rgba(116, 136, 116, 0.05) 100%);
  }

  .section-band--warm {
    background: linear-gradient(160deg, rgba(246, 232, 228, 0.55) 0%, rgba(240, 228, 235, 0.35) 100%);
  }

  .section-band--dark .eyebrow {
    color: rgba(235, 185, 165, 0.85);
  }

  .section-band--dark .eyebrow::before {
    background: rgba(235, 185, 165, 0.7);
  }

  .section-band--dark .section-heading h2 {
    color: white;
  }

  .section-band--dark .section-heading p {
    color: rgba(255, 255, 255, 0.58);
  }

  .section-band--dark .feature {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .section-band--dark .feature:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.25);
    transform: translateY(-3px);
  }

  .section-band--dark .feature strong,
  .section-band--dark .feature--large strong {
    color: white;
  }

  .section-band--dark .feature p,
  .section-band--dark .feature--large p {
    color: rgba(255, 255, 255, 0.6);
  }

  /* ── Dark hero panel ─────────────────────────────────── */

  .hero-panel--dark {
    background: #1a0a10;
    border-color: rgba(255, 255, 255, 0.07);
    backdrop-filter: none;
  }

  .hero-panel--dark:hover {
    border-color: rgba(255, 255, 255, 0.14);
  }

  .hero-panel--dark .hero-panel__content strong {
    color: white;
  }

  .hero-panel--dark .hero-panel__content p {
    color: rgba(255, 255, 255, 0.6);
  }

  .hero-panel--dark .mini-calendar div {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .hero-panel--dark .mini-calendar span {
    color: rgba(255, 255, 255, 0.5);
  }

  .hero-panel--dark .mini-calendar strong {
    color: rgba(235, 185, 165, 0.9);
  }

  .hero-panel--dark .stat-row {
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  .hero-panel--dark .stat-row div {
    border-right-color: rgba(255, 255, 255, 0.08);
  }

  .hero-panel--dark .stat-row strong {
    color: white;
  }

  .hero-panel--dark .stat-row span {
    color: rgba(255, 255, 255, 0.5);
  }

  /* ── Features asymmetric ─────────────────────────────── */

  .features-asymmetric {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
    align-items: stretch;
  }

  .features-stack {
    display: grid;
    gap: 22px;
  }

  .feature--large {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 300px;
  }

  .feature--large strong {
    display: block;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 1.18;
    color: var(--ink);
  }

  .feature--large p {
    font-size: 1.04rem;
    margin-top: 14px;
    line-height: 1.8;
  }

  .feature--large:hover {
    transform: translateY(-3px);
  }

  .feature--compact:hover {
    transform: translateY(-3px);
  }

  /* ── Steps flow ──────────────────────────────────────── */

  .steps-flow {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    position: relative;
    gap: 0;
  }

  .steps-flow::before {
    position: absolute;
    top: 20px;
    left: calc(100% / 6);
    right: calc(100% / 6);
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(185, 120, 130, 0.38) 25%,
      rgba(185, 120, 130, 0.38) 75%,
      transparent
    );
    content: "";
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 32px 4px;
  }

  .step__num {
    position: relative;
    z-index: 1;
    display: flex;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--blush);
    border: 1px solid rgba(185, 120, 130, 0.28);
    color: var(--rose-dark);
    font-size: 0.84rem;
    font-weight: 850;
    margin-bottom: 28px;
  }

  .step h3 {
    margin: 0 0 12px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.38rem;
    font-weight: 500;
    color: var(--ink);
  }

  .step p {
    margin: 0;
  }

  /* ── Testimonials ────────────────────────────────────── */

  .testimonial {
    display: flex;
    flex-direction: column;
  }

  .testimonial__stars {
    color: #c4873a;
    font-size: 0.86rem;
    letter-spacing: 2px;
    margin-bottom: 14px;
  }

  .testimonial > p {
    flex: 1;
    font-style: italic;
  }

  .testimonial__footer {
    display: flex;
    flex-direction: column;
    gap: 3px;
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }

  .testimonial__footer strong {
    color: var(--ink);
    font-size: 0.92rem;
  }

  .testimonial__footer span {
    color: var(--sage);
    font-size: 0.8rem;
    font-weight: 760;
  }

  /* ── Promo band dark variant ─────────────────────────── */

  .promo-band--dark {
    background: linear-gradient(140deg, #1e0d13 0%, #2c1520 60%, #1e0d13 100%);
    border-color: rgba(255, 255, 255, 0.06);
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.22);
  }

  .promo-band--dark .eyebrow {
    color: rgba(235, 188, 168, 0.85);
  }

  .promo-band--dark .eyebrow::before {
    background: rgba(235, 188, 168, 0.7);
  }

  .promo-band--dark h2 {
    color: white;
  }

  .promo-band--dark p {
    color: rgba(255, 255, 255, 0.62);
  }

  .promo-band--dark .button {
    background: white;
    color: #1e0d13;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3);
  }

  .promo-band--dark .button:hover {
    filter: brightness(0.95);
  }

  /* ── Promo cards ─────────────────────────────────────── */

  .promo-card {
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.48);
    backdrop-filter: blur(14px);
    box-shadow: 0 2px 12px rgba(60, 40, 100, 0.06);
    transition:
      transform 300ms var(--ease),
      box-shadow 300ms var(--ease),
      border-color 300ms var(--ease),
      background 300ms var(--ease);
    display: flex;
    min-height: 330px;
    flex-direction: column;
    gap: 14px;
    padding: 30px;
  }

  .promo-card:hover {
    border-color: rgba(255, 255, 255, 0.75);
    background: rgba(255, 255, 255, 0.68);
    box-shadow: 0 12px 40px rgba(60, 40, 100, 0.12);
    transform: translateY(-4px);
  }

  .promo-card h3 {
    margin: 6px 0 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.7rem;
    font-weight: 500;
    line-height: 1.12;
  }

  .promo-card ul {
    display: grid;
    gap: 8px;
    margin: 8px 0 0;
    padding-left: 18px;
