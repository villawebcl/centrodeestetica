---
export const prerender = false;
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { supabase } from "@lib/supabase";
import { withTimeout } from "@lib/api";

const [{ data: config }, { data: services }, { data: professionals }] = await withTimeout(Promise.all([
  supabase.from("configuracion").select("*").single(),
  supabase.from("servicios").select("nombre").filter("activo", "eq", true).order("nombre"),
  supabase.from("profesionales").select("nombre").filter("activo", "eq", true).order("nombre")
]), 3000, [
  { data: null, error: null },
  { data: [], error: null },
  { data: [], error: null }
] as any);

const defaultSlots = ["10:00", "11:30", "13:00", "15:30", "17:00", "18:30"];
const timeRegex = /^([01]\d|2[0-3]):[0-5]\d$/;
const configuredSlots = (Array.isArray(config?.horario_slots) ? config.horario_slots : []) as string[];
const validConfiguredSlots = configuredSlots.filter((slot: string) => timeRegex.test(String(slot)));
const slots: string[] = validConfiguredSlots.length
  ? validConfiguredSlots
  : defaultSlots;
const today = new Date();
const dates = Array.from({ length: 8 }, (_, index) => {
  const date = new Date(today);
  date.setDate(today.getDate() + index + 1);
  return date.toISOString().slice(0, 10);
});

const site = {
  name: config?.nombre_negocio || "Lumina Estetica",
  address: config?.direccion,
  hours: config?.horarios,
  whatsappHref: `https://wa.me/${config?.whatsapp_number}?text=Hola%20${config?.nombre_negocio}%2C%20tengo%20una%20duda%20con%20la%20reserva`
};
---

<BaseLayout
  title="Reservar hora"
  description={`Agenda una evaluacion o tratamiento en ${site.name}.`}
  brandConfig={config}
>
  <section class="page-section">
    <SectionHeading
      eyebrow="Reserva online"
      title="Elige tu tratamiento y solicita una hora."
      text="Te contactaremos para confirmar disponibilidad, resolver dudas y dejar tu visita coordinada."
    />

    <div class="booking-layout">
      <form class="booking-panel booking-form" id="booking-form">
        <div class="form-grid">
          <label>
            Nombre completo
            <input name="name" type="text" placeholder="Ej: Sofia Martinez" required />
          </label>
          <label>
            Telefono
            <input name="phone" type="tel" placeholder="+56 9 1234 5678" required />
          </label>
        </div>

        <label>
          Tratamiento
          <select name="service" required>
            <option value="">Selecciona una opcion</option>
            {services?.map((service: any) => <option value={service.nombre}>{service.nombre}</option>)}
          </select>
        </label>

        <label>
          Profesional
          <select name="professional" required>
            <option value="">Selecciona una opcion</option>
            {professionals?.map((pro: any) => <option value={pro.nombre}>{pro.nombre}</option>)}
          </select>
        </label>

        <div>
          <span class="field-label">Fecha</span>
          <div class="slot-grid date-grid" data-date-grid>
            {
              dates.map((date, index) => (
                <label class="choice-card">
                  <input type="radio" name="date" value={date} required checked={index === 0} />
                  <span data-date-label={date}>{date}</span>
                </label>
              ))
            }
          </div>
        </div>

        <div>
          <span class="field-label">Hora preferida</span>
          <div class="slot-grid" id="time-slots">
            {
              slots.map((slot, index) => (
                <label class="choice-card">
                  <input type="radio" name="time" value={slot} required checked={index === 1} />
                  <span class="slot-label">{slot}</span>
                </label>
              ))
            }
          </div>
          <p id="slots-message" class="slots-message" hidden></p>
        </div>

        <label>
          Comentario opcional
          <textarea
            name="notes"
            placeholder="Cuéntanos si tienes piel sensible, embarazo, alergias o una preferencia horaria."
          ></textarea>
        </label>

        <label class="privacy-consent">
          <input name="consent" type="checkbox" required />
          <span>
            Acepto que mis datos sean usados para gestionar mi solicitud de reserva y contacto,
            de acuerdo con la <a href="/politicas" target="_blank" rel="noreferrer">politica de privacidad</a>.
          </span>
        </label>

        <button class="button" type="submit" id="submit-btn">Solicitar reserva</button>
        <p class="form-note" id="booking-feedback" aria-live="polite"></p>
      </form>

      <aside class="booking-panel booking-summary">
        <p class="eyebrow">Tu visita</p>
        <h2>Confirmacion cercana y sin presion.</h2>
        <p>
          La solicitud queda registrada como pendiente. Nuestro equipo revisa la
          disponibilidad y confirma por telefono o WhatsApp.
        </p>
        <div class="summary-list">
          <div>
            <span>Evaluacion</span>
            <strong>30 min sin costo</strong>
          </div>
          <div>
            <span>Horario</span>
            <strong>{site.hours}</strong>
          </div>
          <div>
            <span>Direccion</span>
            <strong>{site.address}</strong>
          </div>
        </div>
        <a class="button button--secondary" href={site.whatsappHref} target="_blank" rel="noreferrer">
          Consultar por WhatsApp
        </a>
      </aside>
    </div>
  </section>

  <script src="../scripts/reservar.js"></script>

  <style>
    /* ── Booking layout ────────────────────────────────── */

    .booking-layout {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
      gap: 28px;
      align-items: start;
    }

    .booking-panel {
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.76);
      backdrop-filter: blur(18px);
      box-shadow: var(--shadow);
      padding: 30px;
      transition:
        transform 300ms var(--ease),
        box-shadow 300ms var(--ease),
        border-color 300ms var(--ease);
    }

    .booking-panel:hover {
      border-color: rgba(123, 58, 72, 0.18);
      box-shadow: var(--shadow-hover);
    }

    .booking-summary {
      position: sticky;
      top: 118px;
    }

    .booking-summary h2 {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      font-weight: 500;
      line-height: 1.08;
    }

    .summary-list {
      display: grid;
      gap: 12px;
      margin: 26px 0;
    }

    .summary-list div {
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(251, 247, 243, 0.72);
      padding: 16px;
    }

    .summary-list span {
      display: block;
      color: var(--muted);
      font-size: 0.84rem;
    }

    .summary-list strong {
      display: block;
      margin-top: 4px;
      color: var(--ink);
    }

    .slot-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .date-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .choice-card {
      cursor: pointer;
    }

    .choice-card input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .choice-card span {
      display: flex;
      min-height: 48px;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.68);
      color: var(--muted);
      font-weight: 760;
      padding: 10px;
      text-align: center;
      transition:
        transform 240ms var(--ease),
        box-shadow 240ms var(--ease),
        border-color 240ms var(--ease),
        background 240ms var(--ease),
        color 240ms var(--ease);
    }

    .choice-card:hover span {
      border-color: rgba(123, 58, 72, 0.22);
      background: rgba(255, 255, 255, 0.92);
      box-shadow: 0 14px 34px rgba(77, 55, 48, 0.08);
      transform: translateY(-2px);
    }

    .choice-card input:checked + span {
      border-color: rgba(123, 58, 72, 0.36);
      background: linear-gradient(135deg, rgba(123, 58, 72, 0.1), rgba(255, 255, 255, 0.92));
      color: var(--rose-dark);
      box-shadow: 0 16px 38px rgba(123, 58, 72, 0.12);
    }

    /* ── Slots message ─────────────────────────────────── */

    .slots-message {
      margin-top: 0.6rem;
      font-size: 0.85rem;
      padding: 0.5rem 0.75rem;
      border-radius: var(--radius);
    }

    .slots-message--warn {
      background: rgba(180, 83, 9, 0.08);
      color: #92400e;
    }

    /* Slot ocupado */
    .choice-card--taken {
      opacity: 0.4;
      cursor: not-allowed;
      position: relative;
    }

    .choice-card--taken input {
      pointer-events: none;
    }

    .choice-card--taken .slot-label::after {
      content: " · Ocupado";
      font-size: 0.72em;
      opacity: 0.8;
    }

    /* Slot verificando disponibilidad */
    .choice-card--checking {
      opacity: 0.6;
      pointer-events: none;
    }

    @media (max-width: 860px) {
      .booking-layout {
        grid-template-columns: 1fr;
      }

      .booking-summary {
        position: static;
      }
    }

    @media (max-width: 520px) {
      .slot-grid,
      .date-grid {
        grid-template-columns: 1fr;
      }

      .booking-panel {
        padding: 22px;
      }
    }
  </style>
</BaseLayout>
