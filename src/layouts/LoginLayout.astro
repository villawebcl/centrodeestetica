---
import "../styles/global.css";

interface Props {
  siteName?: string;
}
const { siteName = "Mi Centro" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Acceso · Admin</title>
  </head>
  <body class="login-body">
    <div class="login-root">
      <div class="login-card">
        <div class="login-brand">
          <div class="login-brand__mark" aria-hidden="true">{siteName[0]}</div>
          <div>
            <strong class="login-brand__name">{siteName}</strong>
            <span class="login-brand__sub">Panel Admin</span>
          </div>
        </div>
        <slot />
      </div>
    </div>
  </body>
</html>

<style is:global>
  .login-body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: inherit;
  }

  .login-root {
    width: 100%;
    max-width: 420px;
    padding: 1.5rem;
  }

  .login-card {
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2.25rem 2.25rem;
    backdrop-filter: blur(20px);
    box-shadow: 0 4px 40px rgba(60, 40, 100, 0.1);
  }

  .login-brand {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
  }

  .login-brand__mark {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--rose-dark), #c084a0);
    color: white;
    display: grid;
    place-items: center;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.35rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .login-brand__name {
    display: block;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
  }

  .login-brand__sub {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 2px;
  }

  .login-title {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 0.25rem;
    line-height: 1.1;
  }

  .login-subtitle {
    font-size: 0.85rem;
    color: var(--muted);
    margin: 0 0 1.5rem;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .login-error {
    font-size: 0.85rem;
    color: #c0392b;
    background: rgba(220, 38, 38, 0.06);
    border: 1px solid rgba(220, 38, 38, 0.2);
    border-radius: var(--radius);
    padding: 0.6rem 0.9rem;
    margin: 0;
  }
</style>
