---
import "../styles/global.css";
import { site } from "@data/site";

interface Props {
  title?: string;
  description?: string;
}

const { title = site.name, description = site.description } = Astro.props;
const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fbfaf8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="main-nav main-nav--left" aria-label="Navegacion izquierda">
        <a href="/">Inicio</a>
        <a href="/servicios">Servicios</a>
        <a href="/promociones">Promos</a>
      </nav>
      <a class="brand" href="/" aria-label={`${site.name} inicio`}>
        <span class="brand-mark">L</span>
        <strong>{site.name}</strong>
      </a>
      <nav class="main-nav main-nav--right" aria-label="Navegacion derecha">
        <a href="/reservar">Reservar</a>
        <a href="/contacto">Contacto</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>{site.name}</strong>
        <p>{site.address}</p>
      </div>
      <nav class="footer-links" aria-label="Enlaces secundarios">
        <a href="/profesionales">Profesionales</a>
        <a href="/preguntas-frecuentes">Preguntas frecuentes</a>
        <a href="/politicas">Politicas</a>
        <a href="/admin">Admin</a>
      </nav>
      <div>
        <p>{site.hours}</p>
        <a href={`mailto:${site.email}`}>{site.email}</a>
      </div>
    </footer>
    <a class="floating-cta" href={site.ctaHref}>
      Reservar hora
    </a>
  </body>
</html>
