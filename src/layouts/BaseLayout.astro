---
import "../styles/global.css";
import { supabase } from "@lib/supabase";
import { withTimeout } from "@lib/api";

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  brandConfig?: {
    nombre_negocio?: string | null;
    direccion?: string | null;
    horarios?: string | null;
    email?: string | null;
    color_primario?: string | null;
    color_secundario?: string | null;
  } | null;
}

const defaultSite = {
  name: "Lumina Estetica",
  description:
    "Tratamientos esteticos personalizados en un espacio calido, profesional y pensado para que agendes sin complicaciones.",
  address: "Av. Providencia 1234, Santiago",
  hours: "Lunes a sabado, 10:00 a 19:30",
  email: "hola@luminaestetica.cl"
};

const {
  title = defaultSite.name,
  description = defaultSite.description,
  ogTitle,
  ogDescription,
  ogImage = "https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?auto=format&fit=crop&w=1200&q=80",
  brandConfig
} = Astro.props;
const layoutConfig = brandConfig ?? (await withTimeout(supabase
  .from("configuracion")
  .select("nombre_negocio, direccion, horarios, email, color_primario, color_secundario")
  .single(), 2500, { data: null, error: null } as any)).data;

const brandName = layoutConfig?.nombre_negocio || defaultSite.name;
const brandAddress = layoutConfig?.direccion || defaultSite.address;
const brandHours = layoutConfig?.horarios || defaultSite.hours;
const brandEmail = layoutConfig?.email || defaultSite.email;
const hexColorRegex = /^#[0-9a-fA-F]{6}$/;
const brandPrimary = hexColorRegex.test(layoutConfig?.color_primario ?? "") ? layoutConfig?.color_primario : null;
const brandSecondary = hexColorRegex.test(layoutConfig?.color_secundario ?? "") ? layoutConfig?.color_secundario : null;
const pageTitle = title === defaultSite.name || title === brandName ? brandName : `${title} | ${brandName}`;
const socialTitle = ogTitle || pageTitle;
const socialDescription = ogDescription || description;
const canonicalUrl = new URL(Astro.url.pathname, Astro.url.origin).toString();
const socialImage = new URL(ogImage, Astro.url.origin).toString();
const brandStyle = [
  brandPrimary ? `--brand-primary:${brandPrimary}` : "",
  brandSecondary ? `--brand-secondary:${brandSecondary}` : ""
].filter(Boolean).join(";");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fbfaf8" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brandName} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={socialImage} />
    <title>{pageTitle}</title>
  </head>
  <body style={brandStyle}>
    <header class="site-header">
      <nav class="main-nav main-nav--left" aria-label="Navegacion izquierda">
        <a href="/">Inicio</a>
        <a href="/servicios">Servicios</a>
        <a href="/promociones">Promos</a>
      </nav>
      <a class="brand" href="/" aria-label={`${brandName} inicio`}>
        <span class="brand-mark">{brandName.slice(0, 1)}</span>
        <strong>{brandName}</strong>
      </a>
      <nav class="main-nav main-nav--right" aria-label="Navegacion derecha">
        <a href="/reservar">Reservar</a>
        <a href="/contacto">Contacto</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>{brandName}</strong>
        <p>{brandAddress}</p>
      </div>
      <nav class="footer-links" aria-label="Enlaces secundarios">
        <a href="/profesionales">Profesionales</a>
        <a href="/preguntas-frecuentes">Preguntas frecuentes</a>
        <a href="/politicas">Politicas</a>
        <a href="/admin">Admin</a>
      </nav>
      <div>
        <p>{brandHours}</p>
        <a href={`mailto:${brandEmail}`}>{brandEmail}</a>
      </div>
    </footer>
    <a class="floating-cta" href="/reservar">
      Reservar hora
    </a>
    <div class="privacy-banner" id="privacy-banner" hidden>
      <p>
        Usamos cookies tecnicas de sesion y guardamos tus datos solo para responder consultas y gestionar reservas.
        Revisa nuestra <a href="/politicas">politica de privacidad</a>.
      </p>
      <button type="button" class="button button--secondary" id="privacy-banner-ok">Entendido</button>
    </div>
    <script src="/privacy-notice.js" is:inline></script>
  </body>
</html>

<style is:global>
  /* ── Site header ─────────────────────────────────────── */

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 20px 24px;
    background: rgba(180, 170, 210, 0.38);
    backdrop-filter: blur(24px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.28);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    padding: 0 72px;
    transition: opacity 260ms var(--ease);
  }

  .brand:hover {
    opacity: 0.75;
  }

  .brand-mark {
    display: grid;
    width: 36px;
    height: 36px;
    place-items: center;
    border-radius: 50%;
    background: var(--brand-primary);
    color: white;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.1rem;
    font-style: italic;
    font-weight: 500;
  }

  .brand strong {
    display: block;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .brand small {
    display: none;
  }

  .main-nav {
    flex: 1;
    display: flex;
    gap: 28px;
    color: var(--ink);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .main-nav--left {
    justify-content: flex-end;
  }

  .main-nav--right {
    justify-content: flex-start;
  }

  .main-nav a {
    position: relative;
    padding-block: 4px;
    opacity: 0.7;
    transition: opacity 240ms var(--ease);
  }

  .main-nav a:hover {
    opacity: 1;
  }

  /* ── Floating CTA ────────────────────────────────────── */

  .floating-cta {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 30;
    display: none;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: linear-gradient(135deg, #2c8b63, #237652);
    color: white;
    font-weight: 800;
    padding: 0 18px;
    box-shadow: 0 16px 38px rgba(31, 143, 95, 0.28);
    transition: transform 260ms var(--ease), box-shadow 260ms var(--ease);
  }

  .floating-cta:hover {
    transform: translateY(-2px) scale(1.025);
    box-shadow: 0 20px 52px rgba(31, 143, 95, 0.34);
  }

  /* ── Not found ───────────────────────────────────────── */

  .not-found {
    min-height: 62vh;
    display: grid;
    align-content: center;
    justify-items: start;
    gap: 18px;
  }

  .not-found h1 {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    line-height: 1;
  }

  /* ── Privacy banner ──────────────────────────────────── */

  .privacy-banner {
    position: fixed;
    left: 18px;
    right: 18px;
    bottom: 18px;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    max-width: 980px;
    margin: 0 auto;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.94);
    box-shadow: var(--shadow);
    padding: 16px 18px;
    backdrop-filter: blur(18px);
  }

  .privacy-banner[hidden] {
    display: none;
  }

  .privacy-banner p {
    margin: 0;
    font-size: 0.9rem;
  }

  .privacy-banner a,
  .privacy-consent a {
    color: var(--brand-secondary);
    font-weight: 800;
    text-decoration: underline;
  }

  .privacy-consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .privacy-consent input {
    width: auto;
    margin-top: 0.25rem;
  }

  /* ── Site footer ─────────────────────────────────────── */

  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin: 0 auto;
    max-width: 1180px;
    padding: 22px 24px;
    border-top: 1px solid var(--line);
  }

  .site-footer p {
    margin: 6px 0;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 18px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .footer-links a {
    transition: color 220ms var(--ease), transform 220ms var(--ease);
  }

  .footer-links a:hover {
    color: var(--rose-dark);
    transform: translateY(-1px);
  }

  /* ── Responsive ──────────────────────────────────────── */

  @media (max-width: 860px) {
    .site-header {
      flex-wrap: wrap;
      justify-content: center;
    }

    .main-nav {
      order: 3;
      width: 100%;
      justify-content: space-between;
    }

    .main-nav--left,
    .main-nav--right {
      display: none;
    }

    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 520px) {
    .site-header {
      padding-inline: 16px;
    }

    .header-cta {
      width: 100%;
    }

    .floating-cta {
      display: inline-flex;
    }
  }
</style>
