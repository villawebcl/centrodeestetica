---
import "../styles/global.css";
import { supabase } from "@lib/supabase";
import { withTimeout } from "@lib/api";

type Page = "reservas" | "servicios" | "profesionales" | "promociones" | "configuracion" | "cuenta";

interface Props {
  title?: string;
  currentPage: Page;
  siteName?: string;
}

const { title = "Admin", currentPage, siteName } = Astro.props;
const { data: layoutConfig } = await withTimeout(
  supabase.from("configuracion").select("nombre_negocio").single(),
  2500,
  { data: null, error: null } as any
);
const resolvedSiteName = siteName || layoutConfig?.nombre_negocio || "Lumina Estetica";

const nav: { group: string; items: { id: Page; label: string; href: string; icon: string }[] }[] = [
  {
    group: "Gestión",
    items: [
      { id: "reservas", label: "Reservas", href: "/admin", icon: "calendar" },
    ],
  },
  {
    group: "Contenido",
    items: [
      { id: "servicios",      label: "Servicios",      href: "/admin/servicios",      icon: "tag"  },
      { id: "profesionales",  label: "Profesionales",  href: "/admin/profesionales",  icon: "user" },
      { id: "promociones",    label: "Promociones",    href: "/admin/promociones",    icon: "gift" },
    ],
  },
  {
    group: "Sistema",
    items: [
        { id: "configuracion", label: "Configuración", href: "/admin/configuracion", icon: "settings" },
      { id: "cuenta",        label: "Cuenta",         href: "/admin/cuenta",         icon: "lock"     },
    ],
  },
];

const icons: Record<string, string> = {
  calendar: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="1.5" y="3" width="13" height="11.5" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M1.5 6.5h13" stroke="currentColor" stroke-width="1.4"/><path d="M5 1.5V4M11 1.5V4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
  tag:      `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 2h6l5.5 5.5a2 2 0 010 2.83L10 13.83a2 2 0 01-2.83 0L2 8V2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><circle cx="5.5" cy="5.5" r="1" fill="currentColor"/></svg>`,
  user:     `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="5.5" r="2.5" stroke="currentColor" stroke-width="1.4"/><path d="M2.5 13.5c0-2.76 2.46-5 5.5-5s5.5 2.24 5.5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
  gift:     `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="1.5" y="6" width="13" height="8.5" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M1.5 6h13v2.5H1.5V6z" stroke="currentColor" stroke-width="1.4"/><path d="M8 6V14.5M5.5 6c0-2.5-.5-5 2.5-5s2.5 2.5 2.5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  settings: `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="2.5" stroke="currentColor" stroke-width="1.4"/><path d="M8 1.5v1.3M8 13.2v1.3M1.5 8h1.3M13.2 8h1.3M3.4 3.4l.92.92M11.68 11.68l.92.92M3.4 12.6l.92-.92M11.68 4.32l.92-.92" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
  lock:     `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="3" y="7" width="10" height="7.5" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M5 7V5a3 3 0 016 0v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><circle cx="8" cy="10.5" r="1" fill="currentColor"/></svg>`,
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <script src="/admin-ui.js" is:inline></script>
    <title>{title} · Admin</title>
  </head>

  <body class="admin-body">
    <div class="al-root">

      <!-- ── Sidebar ──────────────────────────────── -->
      <aside class="al-sidebar" id="al-sidebar" aria-label="Navegación del panel">
        <div class="al-sidebar__inner">

          <div class="al-brand">
            <div class="al-brand__mark" aria-hidden="true">{resolvedSiteName[0]}</div>
            <div>
              <strong class="al-brand__name">{resolvedSiteName}</strong>
              <span class="al-brand__sub">Panel Admin</span>
            </div>
          </div>

          <nav class="al-nav">
            {nav.map((group) => (
              <div class="al-nav-group">
                <span class="al-nav-label">{group.group}</span>
                {group.items.map((item) => (
                  <a
                    href={item.href}
                    class={`al-nav-item${currentPage === item.id ? " is-active" : ""}`}
                    aria-current={currentPage === item.id ? "page" : undefined}
                  >
                    <span class="al-nav-icon" set:html={icons[item.icon]} />
                    {item.label}
                  </a>
                ))}
              </div>
            ))}
          </nav>

          <div class="al-sidebar__footer">
            <a href="/" class="al-back-link">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M8.5 2.5L4 7l4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Ver sitio web
            </a>
          </div>

        </div>
      </aside>

      <!-- ── Mobile bar ───────────────────────────── -->
      <div class="al-mobile-bar">
        <button class="al-hamburger" id="al-hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="al-sidebar">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <rect x="1" y="3" width="16" height="2" rx="1" fill="currentColor"/>
            <rect x="1" y="8" width="16" height="2" rx="1" fill="currentColor"/>
            <rect x="1" y="13" width="16" height="2" rx="1" fill="currentColor"/>
          </svg>
        </button>
        <span class="al-mobile-title">{resolvedSiteName}</span>
        <a href="/" class="al-mobile-back">Ver sitio →</a>
      </div>

      <!-- ── Main ─────────────────────────────────── -->
      <main class="al-main">
        <div class="al-content">
          <button type="button" class="al-history-back" id="al-history-back">Volver atrás</button>
          <slot />
        </div>
      </main>

    </div>

    <!-- Toast container (global, shared across all admin pages) -->
    <div id="toast-container" aria-live="polite" aria-atomic="false"></div>

    <script type="module" is:inline>
      const hamburger = document.querySelector("#al-hamburger");
      const sidebar   = document.querySelector("#al-sidebar");
      const backBtn   = document.querySelector("#al-history-back");

      backBtn?.addEventListener("click", () => {
        if (history.length > 1) history.back();
        else window.location.href = "/admin";
      });

      hamburger?.addEventListener("click", () => {
        const isOpen = sidebar.classList.toggle("is-open");
        hamburger.setAttribute("aria-expanded", String(isOpen));
      });

      document.addEventListener("click", (e) => {
        if (sidebar.classList.contains("is-open") &&
            !sidebar.contains(e.target) &&
            !hamburger.contains(e.target)) {
          sidebar.classList.remove("is-open");
          hamburger.setAttribute("aria-expanded", "false");
        }
      });
    </script>
  </body>
</html>

<style is:global>
  /* ── Reset admin body ───────────────────────────────── */
  .admin-body {
    margin: 0;
    background: var(--bg);
    font-family: inherit;
  }

  /* ── Root layout ────────────────────────────────────── */
  .al-root {
    display: flex;
    min-height: 100vh;
  }

  /* ── Sidebar ────────────────────────────────────────── */
  .al-sidebar {
    width: 240px;
    flex-shrink: 0;
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    overflow-y: auto;
    background: rgba(253, 252, 255, 0.98);
    border-right: 1px solid var(--line);
    z-index: 100;
    display: flex;
    flex-direction: column;
  }

  .al-sidebar__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 100vh;
  }

  .al-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.4rem 1.25rem 1.2rem;
    border-bottom: 1px solid var(--line);
    flex-shrink: 0;
  }

  .al-brand__mark {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--rose-dark), #c084a0);
    color: white;
    display: grid;
    place-items: center;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.15rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .al-brand__name {
    display: block;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 150px;
  }

  .al-brand__sub {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 2px;
  }

  .al-nav {
    flex: 1;
    padding: 0.6rem 0.75rem;
    overflow-y: auto;
  }

  .al-nav-group {
    margin-bottom: 0.5rem;
  }

  .al-nav-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.75rem 0.5rem 0.3rem;
    opacity: 0.7;
  }

  .al-nav-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.58rem 0.75rem;
    border-radius: 10px;
    text-decoration: none;
    font-size: 0.87rem;
    font-weight: 500;
    color: var(--muted);
    transition:
      background 160ms var(--ease),
      color 160ms var(--ease);
    margin-bottom: 2px;
  }

  .al-nav-item:hover {
    background: rgba(106, 80, 136, 0.07);
    color: var(--ink);
  }

  .al-nav-item.is-active {
    background: rgba(106, 80, 136, 0.12);
    color: var(--rose-dark);
    font-weight: 600;
  }

  .al-nav-icon {
    display: grid;
    place-items: center;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .al-nav-item.is-active .al-nav-icon {
    opacity: 1;
  }

  .al-sidebar__footer {
    padding: 1rem 1.25rem;
    border-top: 1px solid var(--line);
    flex-shrink: 0;
  }

  .al-back-link {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 160ms var(--ease);
  }

  .al-back-link:hover {
    color: var(--ink);
  }

  /* ── Mobile top bar ─────────────────────────────────── */
  .al-mobile-bar {
    display: none;
  }

  /* ── Main content ───────────────────────────────────── */
  .al-main {
    margin-left: 240px;
    flex: 1;
    min-height: 100vh;
  }

  .al-content {
    padding: 2rem 2.5rem 3rem;
    max-width: 1280px;
  }

  .al-history-back {
    border: 0;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.86rem;
    font-weight: 800;
    margin: 0 0 1rem;
    padding: 0;
  }

  .al-history-back:hover {
    color: var(--ink);
  }

  .admin-pagination {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 14px;
    margin-top: 18px;
  }

  .admin-pagination span,
  .admin-loading {
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .admin-loading {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 18px;
  }

  .svc-card__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 12px;
    margin: 0 0 1rem;
  }

  .pro-avatar--image {
    object-fit: cover;
  }

  /* ── Page header ────────────────────────────────────── */
  .al-page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
  }

  .al-page-eyebrow {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.4rem;
  }

  .al-page-title {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.1rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 0.3rem;
    line-height: 1.1;
  }

  .al-page-desc {
    font-size: 0.88rem;
    color: var(--muted);
    margin: 0;
    max-width: 48ch;
  }

  .al-page-actions {
    display: flex;
    gap: 0.6rem;
    flex-shrink: 0;
    padding-top: 0.5rem;
  }

  /* ── KPI cards (dashboard) ──────────────────────────── */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-bottom: 1.75rem;
  }

  .kpi-card {
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.1rem 1.35rem;
    backdrop-filter: blur(12px);
    border-left-width: 3px;
    transition: box-shadow 220ms var(--ease), transform 220ms var(--ease);
  }

  .kpi-card:hover {
    box-shadow: 0 8px 28px rgba(60, 40, 100, 0.1);
    transform: translateY(-2px);
  }

  .kpi-card__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .kpi-card__count {
    display: block;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 2.6rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1;
    margin-top: 0.2rem;
  }

  .kpi-card--pendiente  { border-left-color: #b45309; }
  .kpi-card--confirmada { border-left-color: #52694f; }
  .kpi-card--completada { border-left-color: var(--rose-dark); }
  .kpi-card--cancelada  { border-left-color: var(--muted); }

  /* ── Shared admin card grid ─────────────────────────── */
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }

  .svc-loading,
  .svc-empty {
    text-align: center;
    padding: 2.5rem;
    color: var(--muted);
    grid-column: 1 / -1;
  }

  .svc-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.74);
    backdrop-filter: blur(14px);
    padding: 20px 22px;
    transition:
      transform 260ms var(--ease),
      box-shadow 260ms var(--ease),
      border-color 260ms var(--ease),
      background 260ms var(--ease);
  }

  .svc-card:hover {
    border-color: rgba(123, 58, 72, 0.18);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 14px 44px rgba(60, 40, 100, 0.1);
    transform: translateY(-3px);
  }

  .svc-card--inactive {
    opacity: 0.55;
  }

  .svc-card__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.2rem;
  }

  .svc-card__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    align-items: center;
  }

  .svc-cat-pill {
    font-size: 0.7rem;
  }

  .svc-badge {
    font-size: 0.68rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 999px;
  }

  .svc-badge--off {
    background: rgba(230, 57, 70, 0.1);
    color: #e63946;
  }

  .svc-badge--warn {
    background: rgba(180, 83, 9, 0.1);
    color: #b45309;
  }

  .svc-card__btns {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .svc-btn {
    height: 28px;
    padding: 0 10px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    color: var(--muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.73rem;
    font-weight: 700;
    white-space: nowrap;
    transition:
      background 160ms var(--ease),
      border-color 160ms var(--ease),
      color 160ms var(--ease),
      transform 160ms var(--ease);
  }

  .svc-btn:hover {
    background: white;
    border-color: rgba(123, 58, 72, 0.28);
    color: var(--rose-dark);
    transform: translateY(-1px);
  }

  .svc-btn--danger {
    color: #c0392b;
    border-color: rgba(192, 57, 43, 0.2);
  }

  .svc-btn--danger:hover {
    background: #fff5f5;
    border-color: #e63946;
    color: #e63946;
  }

  .svc-card__name {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.3rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
  }

  .svc-card--inactive .svc-card__name {
    color: var(--muted);
  }

  .svc-card__desc {
    margin: 0;
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .svc-card__price {
    margin-top: auto;
    padding-top: 0.55rem;
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
  }

  .svc-card__price strong {
    color: var(--rose-dark);
    font-size: 1rem;
  }

  .svc-card__dur {
    color: var(--muted);
    font-size: 0.83rem;
  }

  /* ── Profesionales ──────────────────────────────────── */
  .pro-card__body {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: 0.35rem 0 0.2rem;
  }

  .pro-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--rose-dark), #c084a0);
    color: white;
    display: grid;
    place-items: center;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.3rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .pro-especialidad {
    margin: 0;
    font-size: 0.81rem;
    color: var(--muted);
  }

  /* ── Promociones ────────────────────────────────────── */
  .promo-incluye {
    margin: 0.35rem 0 0;
    padding-left: 1.1rem;
    font-size: 0.81rem;
    color: var(--muted);
    line-height: 1.65;
  }

  .promo-antes {
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: line-through;
  }

  /* ── Modal dialog ───────────────────────────────────── */
  .svc-dialog {
    width: min(540px, calc(100vw - 2rem));
    max-height: calc(100dvh - 4rem);
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: var(--radius-lg);
    background: rgba(253, 252, 255, 0.95);
    backdrop-filter: blur(28px);
    box-shadow:
      0 0 0 1px rgba(90, 80, 140, 0.06),
      0 40px 100px rgba(28, 24, 56, 0.24);
    padding: 0;
    overflow: hidden;
    overscroll-behavior: contain;
  }

  .svc-dialog::backdrop {
    background: rgba(20, 16, 40, 0.52);
    backdrop-filter: blur(5px);
  }

  .svc-dialog[open] {
    animation: svc-dialog-in 260ms var(--ease) both;
  }

  @keyframes svc-dialog-in {
    from { opacity: 0; transform: scale(0.95) translateY(12px); }
    to   { opacity: 1; transform: scale(1)    translateY(0);    }
  }

  .svc-dialog__inner {
    overflow-y: auto;
    max-height: calc(100dvh - 4rem);
  }

  .svc-dialog__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.75rem 2rem 0;
  }

  .svc-dialog__header h2 {
    margin: 4px 0 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.9rem;
    font-weight: 500;
    line-height: 1.05;
    color: var(--ink);
  }

  .svc-dialog__close {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    border: 1px solid var(--line);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.6);
    color: var(--muted);
    cursor: pointer;
    font-size: 0.9rem;
    margin-top: 4px;
    transition:
      background 160ms var(--ease),
      border-color 160ms var(--ease),
      color 160ms var(--ease);
  }

  .svc-dialog__close:hover {
    background: rgba(230, 57, 70, 0.08);
    border-color: rgba(230, 57, 70, 0.35);
    color: #e63946;
  }

  .svc-dialog .booking-form {
    padding: 1.25rem 2rem 1.75rem;
  }

  .svc-dialog .form-status {
    margin: 0.5rem 2rem 0;
